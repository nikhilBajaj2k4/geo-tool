# Copy to .env or export into your shell.
# You need ONE provider's key (OpenRouter is recommended; it exposes Perplexity Sonar).

# Recommended — get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Alternative — get a key at https://z.ai/manage-apikey/apikey-list (must have balance)
ZAI_API_KEY=
